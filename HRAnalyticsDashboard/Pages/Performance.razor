@page "/performance"
@inject DashboardService DashboardService
@inject InsightService InsightService
@using ApexCharts
@using MudColor = MudBlazor.Color
@using MudSize = MudBlazor.Size

<PageTitle>Performance et absenteisme</PageTitle>

<div class="dashboard-page">
    <section class="dashboard-hero">
        <div>
            <MudText Typo="Typo.h4" Class="font-weight-bold">Performance et absenteisme</MudText>
            <MudText Typo="Typo.body1" Class="mt-2">
                Analyse des absences, de la satisfaction manageriale, de l'engagement et des projets speciaux.
            </MudText>
        </div>

        <MudChip Color="MudColor.Info" Variant="Variant.Filled" Size="MudSize.Large">
            Performance
        </MudChip>
    </section>

    @if (_loading)
    {
        <div class="dashboard-empty">
            <MudProgressCircular Color="MudColor.Primary" Indeterminate="true" Size="MudSize.Large" />
        </div>
    }
    else
    {
        <MudGrid>
            <MudItem xs="12" lg="6">
                <ChartCard Title="Absences par poste" Subtitle="Vue barres sur les roles les plus exposes">
                    <ApexChart TItem="PositionMetric" Height="320">
                        <ApexPointSeries TItem="PositionMetric"
                                         Items="_positions"
                                         Name="Absences"
                                         SeriesType="SeriesType.Bar"
                                         XValue="e => e.Position"
                                         YValue="e => e.TotalAbsences" />
                    </ApexChart>
                </ChartCard>
            </MudItem>

            <MudItem xs="12" lg="6">
                <ChartCard Title="Satisfaction par manager" Subtitle="Courbe des meilleurs niveaux de satisfaction">
                    <ApexChart TItem="ManagerMetric" Height="320">
                        <ApexPointSeries TItem="ManagerMetric"
                                         Items="_managers"
                                         Name="Satisfaction"
                                         SeriesType="SeriesType.Line"
                                         XValue="e => e.ManagerName"
                                         YValue="e => e.AverageSatisfaction" />
                    </ApexChart>
                </ChartCard>
            </MudItem>

            <MudItem xs="12" lg="7">
                <ChartCard Title="Engagement par departement" Subtitle="Zone d'intensite de l'engagement RH">
                    <ApexChart TItem="DepartmentMetric" Height="320">
                        <ApexPointSeries TItem="DepartmentMetric"
                                         Items="_engagementByDepartment"
                                         Name="Engagement"
                                         SeriesType="SeriesType.Area"
                                         XValue="e => e.Department"
                                         YValue="e => e.AverageEngagement" />
                    </ApexChart>
                </ChartCard>
            </MudItem>

            <MudItem xs="12" lg="5">
                <ChartCard Title="Projets speciaux par performance" Subtitle="Lecture en donut du niveau de contribution">
                    <MudChart ChartType="MudBlazor.ChartType.Donut"
                              InputData="@_performanceDonutValues"
                              InputLabels="@_performanceDonutLabels"
                              Width="100%"
                              Height="300px" />
                </ChartCard>
            </MudItem>

            <MudItem xs="12">
                <ChartCard Title="Insights performance" Subtitle="Messages automatiques sur l'absenteisme et la performance">
                    <div class="insight-stack">
                        @foreach (var insight in _insights.Where(x => x.Category is "Absenteisme" or "Performance").Take(4))
                        {
                            <InsightCard Item="insight" />
                        }
                    </div>
                </ChartCard>
            </MudItem>
        </MudGrid>
    }
</div>

@code {
    private bool _loading = true;
    private List<PositionMetric> _positions = new();
    private List<ManagerMetric> _managers = new();
    private List<DepartmentMetric> _engagementByDepartment = new();
    private List<PerformanceMetric> _performances = new();
    private List<InsightItem> _insights = new();
    private string[] _performanceDonutLabels = Array.Empty<string>();
    private double[] _performanceDonutValues = Array.Empty<double>();

    protected override async Task OnInitializedAsync()
    {
        _positions = await DashboardService.GetAbsencesByPositionAsync();
        _managers = await DashboardService.GetSatisfactionByManagerAsync();
        _engagementByDepartment = await DashboardService.GetEngagementByDepartmentAsync();
        _performances = await DashboardService.GetProjectsByPerformanceAsync();
        _insights = await InsightService.GenerateInsightsAsync();

        _performanceDonutLabels = _performances.Select(x => x.PerformanceScore).ToArray();
        _performanceDonutValues = _performances.Select(x => (double)x.TotalProjects).ToArray();

        _loading = false;
    }
}
